{
  "palette": {
    "--white": "#fff",
    "--te-white": "#f5f5f5",
    "--te-black": "#0f0e12",
    "--te-grey-100": "#e5e5e5",
    "--te-grey-200": "#ccc",
    "--te-grey-300": "#b2b2b2",
    "--te-grey-500": "#a1a7af",
    "--te-grey-600": "#767676",
    "--te-grey-700": "#7f7f7f",
    "--te-grey-900": "#4d4d4d",
    "--te-grey-1000": "#272727",
    "--te-blue": "#0071bb",
    "--te-green": "#006837",
    "--te-orange": "#f05a24",
    "--te-red": "#b81d13",
    "--te-yellow": "#fab413",
    "--error": "#c0262c",
    "--theme-body-bc": "#fff",
    "--product-background-color": "#f5f5f5"
  },
  "type": {
    "--te-20": "\"te-20\", \"Unicode\", sans-serif",
    "--te-40": "\"te-40\", \"Unicode\", sans-serif",
    "--fw-thin": "100",
    "--fw-light": "300",
    "--fs-10": "calc(.00918367 * var(--client-width))",
    "--fs-15": "calc(.0132653 * var(--client-width))",
    "--fs-20": "calc(.0183673 * var(--client-width))",
    "--fs-25": "calc(.0234694 * var(--client-width))",
    "--fs-30": "calc(.027551 * var(--client-width))",
    "--fs-40": "calc(.0367347 * var(--client-width))",
    "--lh-10": "calc(.0102041 * var(--client-width))",
    "--lh-15": "calc(.0153061 * var(--client-width))",
    "--lh-20": "calc(.0204082 * var(--client-width))",
    "--lh-25": "calc(.0306122 * var(--client-width))",
    "--lh-30": "calc(.0306122 * var(--client-width))",
    "--lh-40": "calc(.0408163 * var(--client-width))",
    "--txt-letter-spacing": "calc(var(--txt-px-unit) * -.5 * var(--txt-scale))",
    "--txt-word-break": "keep-all",
    "html-font-size": "1.63265vw",
    "html-font-family": "var(--te-20)",
    "html-font-weight": "var(--fw-light)"
  },
  "spacing": {
    "--space-xs": "calc(.00510204 * var(--client-width))",
    "--space-sm": "calc(.0102041 * var(--client-width))",
    "--space-md": "calc(.0153061 * var(--client-width))",
    "--space-lg": "calc(.0229592 * var(--client-width))",
    "--space-xl": "calc(.0459184 * var(--client-width))",
    "--block-margin": "var(--space-xl)",
    "--tile-padding": "1vw"
  },
  "radius": {
    "--tile-border-radius": "0",
    "--field-border-radius": "0",
    "--quantity-border-radius": "0",
    "--round": "9999px"
  },
  "layout": {
    "--client-width": "100vw",
    "--base-design-width": "980",
    "--header-height": "calc(.0816327 * var(--client-width))",
    "--footer-height": "calc(.0663265 * var(--client-width))",
    "--page-height": "calc(100vh - var(--header-height))",
    "--footer-column": "calc(.219388 * var(--client-width))",
    "--button-height-sm": "calc(.0357143 * var(--client-width))",
    "--button-height-md": "calc(.0510204 * var(--client-width))",
    "--button-height-lg": "calc(.0663265 * var(--client-width))",
    "--btn-px": "calc(.00816327 * var(--client-width))",
    "--btn-min-click-area": "48px",
    "--border-width": ".75px",
    "--grid-divider": "calc(.00102041 * var(--client-width))",
    "--grid-columns": "repeat(12,minmax(0,1fr))",
    "--z-over": "100",
    "--z-navigation": "1000",
    "--z-modal-backdrop": "2000",
    "--z-dialog": "2001"
  },
  "motion": {
    "transition-default": "all .4s",
    "transition-hover": "background-color .2s ease-in",
    "transition-press": "transform .2s ease-in",
    "transition-reveal": "visibility .1s, opacity .1s",
    "transition-fade": "opacity .15s",
    "--mrq-duration": "12s (marquee loop)",
    "--theme-dt": "0s"
  }
}